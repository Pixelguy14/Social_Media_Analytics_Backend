rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /messages/{messageId} {
      allow read: if true;
      allow write: if request.resource.data.username == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username;
    }
    match /rooms/{roomId}/messages/{messageId} {
      allow read: if true;
      allow write: if request.resource.data.username == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username;
    }
  }
}
